ount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"33","messages":"34","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"35","messages":"36","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"37","messages":"38","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/App.tsx",[],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/index.tsx",[],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/styles/global.ts",[],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/routes/index.tsx",[],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/pages/Home/index.tsx",["39"],"import React, { useState, useEffect } from \"react\";\nimport { FiAlertCircle, FiGithub, FiCodepen } from \"react-icons/fi\";\n\nimport logoImg from \"../../assets/logo.svg\";\n\nimport api from \"../../services/api\";\n\nimport Button from \"../../components/Button\";\nimport {\n  Container,\n  Content,\n  Navbar,\n  Main,\n  HomeTitle,\n  HomeTitleContent,\n  Repositories,\n  Repository,\n  RepositoryTitle,\n  NavbarContent,\n  Logo,\n} from \"./styles\";\n\ninterface IRepositorie {\n  name: string;\n  id: number;\n  html_url: string;\n  description: string;\n}\n\nconst Home: React.FC = () => {\n  const repo = \"https://github.com/siomar\";\n  const [repositories, setRepositories] = useState([]);\n  useEffect(() => {\n    api\n      .get(\"https://api.github.com/users/siomar/repos\")\n      .then((response) => setRepositories(response.data));\n  }, []);\n\n  const openRepository = () => {\n    window.location.href = repo;\n  };\n\n  return (\n    <Container>\n      <Navbar>\n        <NavbarContent>\n          <Logo src={logoImg} alt=\"Siomar Velloso | Desenvolvedor Front-end\" />\n          <a href={repo} target=\"__blank\">\n            <FiAlertCircle />\n          </a>\n        </NavbarContent>\n      </Navbar>\n      <Main>\n        <HomeTitle>\n          <HomeTitleContent>\n            <>\n              <h1>\n                Desenvolvedor Front-web que ama desenvolvimento mobile híbrido.\n                Bem-vindo à minha Sandbox.{\" \"}\n                <FiCodepen style={{ marginBottom: -6 }} />\n              </h1>\n              <Button type=\"button\" onClick={openRepository}>\n                <FiGithub /> Github\n              </Button>\n            </>\n          </HomeTitleContent>\n        </HomeTitle>\n        <Repositories>\n          {repositories.map((repo: IRepositorie) => (\n            <Repository key={repo.id} href={repo.html_url} target=\"__blank\">\n              <RepositoryTitle>\n                <FiGithub />\n                {repo.name}\n              </RepositoryTitle>\n              <p>{repo.description}</p>\n            </Repository>\n          ))}\n        </Repositories>\n      </Main>\n    </Container>\n  );\n};\n\nexport default Home;\n","/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/pages/Home/styles.ts",["40"],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/services/api.ts",[],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/components/Button/index.tsx",[],"/Users/siomarvelloso/Projects/Siomar/siomar.github.io/src/components/Button/styles.ts",[],{"ruleId":"41","severity":1,"message":"42","line":11,"column":3,"nodeType":"43","messageId":"44","endLine":11,"endColumn":10},{"ruleId":"41","severity":1,"message":"45","line":2,"column":10,"nodeType":"43","messageId":"44","endLine":2,"endColumn":15},"@typescript-eslint/no-unused-vars","'Content' is defined but never used.","Identifier","unusedVar","'shade' is defined but never used."]